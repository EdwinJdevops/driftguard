DATABASE_URL=postgresql+asyncpg://user:pass@host/driftguard
REDIS_URL=redis://localhost:6379/0
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App credentials — used for PR automation (backend/integrations/github_pr.py).
# Different from GITHUB_CLIENT_ID/SECRET above, which are for user-facing OAuth login.
# Create a GitHub App under Settings > Developer settings > GitHub Apps.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
ALLOWED_ORIGINS=http://localhost:3000
