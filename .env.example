DATABASE_URL=postgresql+asyncpg://user:pass@host/driftguard
REDIS_URL=redis://localhost:6379/0
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App credentials — used for PR automation (backend/integrations/github_pr.py).
# Different from GITHUB_CLIENT_ID/SECRET above, which are for user-facing OAuth login.
# Create a GitHub App under Settings > Developer settings > GitHub Apps.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# AWS account ID that is the trusted principal in customer IAM trust
# policies for cross-account AssumeRole (see backend/integrations/aws_auth.py).
# Only needed for the multi-tenant SaaS flow — self-hosted single-account
# deployments using the ambient credential chain can leave this unset.
DRIFTGUARD_AWS_ACCOUNT_ID=
ALLOWED_ORIGINS=http://localhost:3000
